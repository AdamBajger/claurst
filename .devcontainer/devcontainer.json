{
  "name": "claurst-rust",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "username": "vscode",
      "uid": "1000",
      "gid": "1000"
    },
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "remoteUser": "vscode",

  "mounts": [
    "source=${localEnv:GPG_AGENT_SOCKET},target=${localEnv:GPG_AGENT_SOCKET},type=bind"
  ],

  "remoteEnv": {
    "GPG_AGENT_SOCKET": "${localEnv:GPG_AGENT_SOCKET}",
    "GNUPGHOME": "/home/vscode/.gnupg",
    "GPG_TTY": "/dev/tty",
    "GIT_TERMINAL_PROMPT": "1"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.inheritEnv": true,
        "git.enableCommitSigning": true
      }
    }
  }
}